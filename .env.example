# Vercel serverless functions require this. Value is pulled from the mvpkit key store.
OPENAI_API_KEY=

# Private GitHub 저장소 가져오기(/api/github-import)에 사용. 서버 전용 비밀값.
GITHUB_TOKEN=

# Firebase Admin 서비스계정 키(JSON)를 base64로 인코딩한 값.
# /api/github-import(ZIP 업로드), /api/download(구매검증+서명URL)에서 사용. 서버 전용 비밀값.
FIREBASE_SERVICE_ACCOUNT_B64=

# Optional overrides (defaults are set in code: gpt-5.4-mini / gpt-image-2 / medium)
# OPENAI_TEXT_MODEL=
# OPENAI_IMAGE_MODEL=
# OPENAI_IMAGE_QUALITY=
